# Public application URL used by authentication and Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Connect dialog values. Publishable keys are safe for browser use;
# authorization is enforced by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key used for verified Stripe webhooks and founder provisioning.
# Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# Stripe test-mode values. Production keys should only be added in Vercel.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Set to true only for design previews without a configured backend.
NEXT_PUBLIC_BDB_DEMO_MODE=false
