# Public Supabase connection (safe for the browser; access is enforced by RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only credentials — never prefix these with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=

# Comma-separated emails allowed to bootstrap the first founder account.
# After first login, founders must enrol MFA before /admin is accessible.
BDB_FOUNDER_EMAILS=

NEXT_PUBLIC_APP_URL=http://localhost:3000
