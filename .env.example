# Public Supabase connection (safe for the browser; access is enforced by RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only credentials — never prefix these with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=

# BDB Operator execution. Keep the default unconfigured until a provider has
# passed its sandbox acceptance journey. Use mock only for demos/pilots where
# every simulated outcome is visibly labelled and excluded from verified value.
OPERATOR_DEFAULT_PROVIDER_MODE=unconfigured
OPERATOR_WEBHOOK_URL=
OPERATOR_WEBHOOK_SECRET=

# Public sales intake. The hash secret is used to rate-limit without retaining
# raw IP addresses. The signed webhook is optional because the database remains
# the durable source of truth when a downstream CRM is unavailable.
SALES_INTAKE_HASH_SECRET=
SALES_INTAKE_WEBHOOK_URL=
SALES_INTAKE_WEBHOOK_SECRET=

# Invitation membership lifetime. Keep exactly aligned with Supabase Email OTP expiration.
# BDB OS currently clamps values to 300–3600 seconds and uses the hosted default of one hour.
BDB_INVITATION_TTL_SECONDS=3600

# Founder access. Keep real values in Vercel, never in GitHub or ClickUp.
# Comma-separated approved founder emails.
BDB_FOUNDER_EMAILS=
# Comma-separated display names in the same order as BDB_FOUNDER_EMAILS.
BDB_FOUNDER_NAMES=
# Explicit one-time gate. Keep false after initial installation.
BDB_FOUNDER_BOOTSTRAP_ENABLED=false
# Emergency-only override when platform-admin rows already exist.
BDB_FOUNDER_BOOTSTRAP_ALLOW_EXISTING=false
# One-time temporary password, minimum 16 characters. Remove after bootstrap.
FOUNDER_INITIAL_PASSWORD=
# Independent high-entropy control, minimum 32 characters. Rotate/remove after use.
FOUNDER_BOOTSTRAP_SECRET=
