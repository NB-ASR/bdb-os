# Public Supabase connection (safe for the browser; access is enforced by RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only credentials — never prefix these with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=

# Invitation membership lifetime. Keep aligned with Supabase Email OTP expiration.
# Values are clamped to 300–86400 seconds by the application.
BDB_INVITATION_TTL_SECONDS=86400

# Founder access. Keep real values in Vercel, never in GitHub or ClickUp.
# Comma-separated approved founder emails.
BDB_FOUNDER_EMAILS=
# Comma-separated display names in the same order as BDB_FOUNDER_EMAILS.
BDB_FOUNDER_NAMES=
# Explicit one-time gate. Keep false after initial installation.
BDB_FOUNDER_BOOTSTRAP_ENABLED=false
# Emergency-only override when platform-admin rows already exist.
BDB_FOUNDER_BOOTSTRAP_ALLOW_EXISTING=false
# One-time temporary password, minimum 16 characters. Remove after bootstrap.
FOUNDER_INITIAL_PASSWORD=
# Independent high-entropy control, minimum 32 characters. Rotate/remove after use.
FOUNDER_BOOTSTRAP_SECRET=
