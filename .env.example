# Public Supabase connection (safe for the browser; access is enforced by RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only credentials — never prefix these with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=

# Founder access. Keep the real values in Vercel, never in GitHub.
# Comma-separated approved founder emails.
BDB_FOUNDER_EMAILS=
# Shared one-time bootstrap password. Every Founder is forced to replace it.
FOUNDER_INITIAL_PASSWORD=
# Strong random bearer secret used once to call /api/admin/bootstrap-founders.
FOUNDER_BOOTSTRAP_SECRET=
